        [Fact]
        public async Task CreateAsync_WithInvalidProvider_ReturnsFail()
        {
            // Arrange
            int providerId = 999;
            var request = new ProviderServiceRequest
            {
                Name = "Service",
                Category = "Beauty",
                PriceEur = 50,
                DurationMinutes = 60
            };

            _mockUserRepository.Setup(r => r.GetByIdAsync(providerId))
                .ReturnsAsync((User)null);

            // Act
            var result = await _service.CreateAsync(providerId, request);

            // Assert
            Assert.False(result.Success);
            Assert.Contains("Provider not found", result.Message);
        }

        [Fact]
        public async Task CreateAsync_WithTooShortDuration_ReturnsFail()
        {
            // Arrange
            int providerId = 1;
            var provider = new User { Id = providerId, Role = UserRole.Provider };
            var request = new ProviderServiceRequest
            {
                Name = "Service",
                Category = "Beauty",
                PriceEur = 50,
                DurationMinutes = 3 // Invalid: less than 5 minutes
            };

            _mockUserRepository.Setup(r => r.GetByIdAsync(providerId))
                .ReturnsAsync(provider);

            // Act
            var result = await _service.CreateAsync(providerId, request);

            // Assert
            Assert.False(result.Success);
            Assert.Contains("Duration must be at least 5 minutes", result.Message);
        }

        [Fact]
        public async Task CreateAsync_WithNegativePrice_ReturnsFail()
        {
            // Arrange
            int providerId = 1;
            var provider = new User { Id = providerId, Role = UserRole.Provider };
            var request = new ProviderServiceRequest
            {
                Name = "Service",
                Category = "Beauty",
                PriceEur = -50, // Invalid: negative price
                DurationMinutes = 60
            };

            _mockUserRepository.Setup(r => r.GetByIdAsync(providerId))
                .ReturnsAsync(provider);

            // Act
            var result = await _service.CreateAsync(providerId, request);

            // Assert
            Assert.False(result.Success);
            Assert.Contains("Price must be non-negative", result.Message);
        }

        [Fact]
        public async Task DeleteAsync_WithValidService_MarkAsInactive()
        {
            // Arrange
            int providerId = 1;
            int serviceId = 100;
            var service = new ProviderService
            {
                Id = serviceId,
                ProviderId = providerId,
                Name = "Service",
                IsActive = true,
                ImageUrl = "/images/service.jpg"
            };

            _mockProviderServiceRepository.Setup(r => r.GetByIdAndProviderAsync(serviceId, providerId))
                .ReturnsAsync(service);

            // Act
            var result = await _service.DeleteAsync(providerId, serviceId);

            // Assert
            Assert.True(result.Success);
            Assert.True(result.Data);
            _mockProviderServiceRepository.Verify(r => r.SaveChangesAsync(), Times.Once);
        }

        [Fact]
        public async Task DeleteAsync_WithNonExistentService_ReturnsFail()
        {
            // Arrange
            int providerId = 1;
            int serviceId = 999;

            _mockProviderServiceRepository.Setup(r => r.GetByIdAndProviderAsync(serviceId, providerId))
                .ReturnsAsync((ProviderService)null);

            // Act
            var result = await _service.DeleteAsync(providerId, serviceId);

            // Assert
            Assert.False(result.Success);
            Assert.Contains("Service not found", result.Message);
        }

        [Fact]
        public async Task GetMyServicesAsync_ReturnsProviderServices()
        {
            // Arrange
            int providerId = 1;
            var provider = new User { Id = providerId, FirstName = "John", LastName = "Doe" };
            var services = new List<ProviderService>
            {
                new ProviderService { Id = 1, Name = "Service1", Provider = provider, ProviderId = providerId },
                new ProviderService { Id = 2, Name = "Service2", Provider = provider, ProviderId = providerId }
            };

            _mockProviderServiceRepository.Setup(r => r.GetByProviderActiveAsync(providerId))
                .ReturnsAsync(services);

            // Act
            var result = await _service.GetMyServicesAsync(providerId);

            // Assert
            Assert.True(result.Success);
            Assert.NotNull(result.Data);
            Assert.Equal(2, result.Data.Count);
        }

        [Fact]
        public async Task SearchAsync_WithCategoryFilter_ReturnsFilteredServices()
        {
            // Arrange
            var provider = new User { Id = 1, FirstName = "Jane", LastName = "Smith" };
            var services = new List<ProviderService>
            {
                new ProviderService { Id = 1, Name = "Haircut", Category = "Beauty", Provider = provider },
                new ProviderService { Id = 2, Name = "Styling", Category = "Beauty", Provider = provider }
            };

            _mockProviderServiceRepository.Setup(r => r.SearchActiveAsync("Beauty", null))
                .ReturnsAsync(services);

            // Act
            var result = await _service.SearchAsync("Beauty", null);

            // Assert
            Assert.True(result.Success);
            Assert.Equal(2, result.Data.Count);
            Assert.All(result.Data, s => Assert.Equal("Beauty", s.Category));
        }

        [Fact]
        public async Task GetCategoriesAsync_ReturnsPredefinedCategories()
        {
            // Act
            var result = await _service.GetCategoriesAsync();

            // Assert
            Assert.True(result.Success);
            Assert.NotEmpty(result.Data);
            Assert.Contains("Haircut", result.Data);
            Assert.Contains("Fitness", result.Data);
            Assert.Contains("Photography", result.Data);
        }

        [Fact]
        public async Task GetProvidersAsync_WithFilters_ReturnsFilteredProviders()
        {
            // Arrange
            var providers = new List<User>
            {
                new User
                {
                    Id = 1,
                    FirstName = "John",
                    LastName = "Doe",
                    CompanyName = "John's Salon",
                    PrimaryCategory = "Beauty",
                    City = "Belgrade",
                    Address = "Main St 1",
                    ProfileImagePath = "/images/provider.jpg",
                    ProviderServices = new List<ProviderService> { new ProviderService() }
                }
            };

            _mockUserRepository.Setup(r => r.GetProvidersFilteredAsync("Beauty", "Belgrade", null))
                .ReturnsAsync(providers);

            // Act
            var result = await _service.GetProvidersAsync("Beauty", "Belgrade", null, "name");

            // Assert
            Assert.True(result.Success);
            Assert.Single(result.Data);
            Assert.Equal("John's Salon", result.Data[0].Name);
            Assert.Equal("Beauty", result.Data[0].PrimaryCategory);
        }

        [Fact]
        public async Task UpdateAsync_WithValidData_ReturnsSuccess()
        {
            // Arrange
            int providerId = 1;
            int serviceId = 100;
            var service = new ProviderService
            {
                Id = serviceId,
                ProviderId = providerId,
                Name = "Old Name",
                PriceEur = 30
            };
            var request = new ProviderServiceRequest
            {
                Name = "New Name",
                Category = "Beauty",
                PriceEur = 40,
                DurationMinutes = 60
            };

            _mockProviderServiceRepository.Setup(r => r.GetByIdAndProviderAsync(serviceId, providerId))
                .ReturnsAsync(service);

            // Act
            var result = await _service.UpdateAsync(providerId, serviceId, request);

            // Assert
            Assert.True(result.Success);
            _mockProviderServiceRepository.Verify(r => r.SaveChangesAsync(), Times.Once);
        }
    }
}
